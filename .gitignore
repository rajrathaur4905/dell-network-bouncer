# Python cache and build artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment files
.env
.env.*
.streamlit/secrets.toml

# Logs and local runtime files
*.log
*.tmp
*.bak

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Generated project outputs
data/processed/
exports/
reports/

# Large or local raw datasets can be added manually when needed.
# Keep data/cleaned/ and data/schema/ trackable for the hackathon demo.
data/raw/

# Keep the canonical trained model in models/.
# Avoid accidentally committing duplicate local model copies under source code.
src/detection/models/*.pkl
src/detection/models/*.joblib

# Notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Local Streamlit runtime state
.streamlit/cache/
